# Bharat Sahayak API - Environment Configuration
# Copy this file to .env and fill in the actual values

# DynamoDB Configuration
# The name of the DynamoDB table used for session management and data storage
DYNAMODB_TABLE=bharat-sahayak-table

# S3 Configuration
# S3 bucket name for temporary audio file storage (used by voice features)
# Files are automatically deleted after 1 hour
S3_TEMP_BUCKET=bharat-sahayak-temp

# Amazon Bedrock Configuration
# Model ID for AI chat responses
# Default: anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# AWS Region Configuration
# AWS region where services are deployed
# Note: Boto3 will use AWS_DEFAULT_REGION or AWS_REGION from environment
# or fall back to AWS CLI configuration
AWS_REGION=ap-south-1

# Logging Configuration
# Log level for application logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO
